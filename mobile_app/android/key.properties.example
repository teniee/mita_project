# Android Release Keystore Configuration
# Copy this file to key.properties and fill in your values.
# NEVER commit key.properties to version control.
#
# To generate a keystore:
#   keytool -genkey -v -keystore mita-release.keystore \
#     -alias mita -keyalg RSA -keysize 2048 -validity 10000
#
storePassword=YOUR_KEYSTORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=mita
storeFile=../mita-release.keystore
